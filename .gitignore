cat > .gitignore << 'EOF'
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
backend/venv/
venv/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.DS_Store?
._*

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock
.salarite.db

# Node modules
frontend/node_modules/
frontend/dist/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*
backend/.env*

# Coverage
coverage/
.nyc_output
EOF

backend/salarite.db
!backend/.env.example
!frontend/.env.example